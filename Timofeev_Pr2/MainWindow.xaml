<Window x:Class="Timofeev_Pr2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Timofeev_Pr2"
        mc:Ignorable="d"
        Title="MainWindow" Height="510" Width="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="input" HorizontalAlignment="Center" Height="50" TextWrapping="Wrap" VerticalAlignment="Top" Width="380" FontSize="20"/>
        <TextBox x:Name="output" HorizontalAlignment="Center" Height="50" TextWrapping="Wrap" VerticalAlignment="Top" Width="380" Margin="0,50,0,0" FontSize="20"/>
        <Button Content="(" Click="Br_o" HorizontalAlignment="Left" Height="77" Margin="0,100,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="1" Click="One" HorizontalAlignment="Left" Height="77" Margin="0,177,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="4" Click="Four" HorizontalAlignment="Left" Height="77" Margin="0,254,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="7" Click="Seven" HorizontalAlignment="Left" Height="78" Margin="0,331,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content=")" Click="Br_c" HorizontalAlignment="Left" Height="77" Margin="100,100,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="2" Click="Two" HorizontalAlignment="Left" Height="77" Margin="100,177,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="5" Click="Five" HorizontalAlignment="Left" Height="77" Margin="100,254,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="8" Click="Eight" HorizontalAlignment="Left" Height="78" Margin="100,331,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="^" Click="Pow_up" HorizontalAlignment="Left" Height="77" Margin="200,100,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="3" Click="Three" HorizontalAlignment="Left" Height="77" Margin="200,177,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="6" Click="Six" HorizontalAlignment="Left" Height="77" Margin="200,254,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="9" Click="Nine" HorizontalAlignment="Left" Height="78" Margin="200,331,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="/" Click="Divide" HorizontalAlignment="Left" Height="77" Margin="298,100,0,0" VerticalAlignment="Top" Width="102" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="*" Click="Multiply" HorizontalAlignment="Left" Height="77" Margin="298,177,0,0" VerticalAlignment="Top" Width="102" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="-" Click="Minus" HorizontalAlignment="Left" Height="77" Margin="298,254,0,0" VerticalAlignment="Top" Width="102" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="+" Click="Plus" HorizontalAlignment="Left" Height="78" Margin="298,331,0,0" VerticalAlignment="Top" Width="102" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="C" Click="Erase" HorizontalAlignment="Left" Height="78" Margin="0,406,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="0" Click="Zero" HorizontalAlignment="Left" Height="78" Margin="100,406,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="." Click="Point" HorizontalAlignment="Left" Height="78" Margin="200,406,0,0" VerticalAlignment="Top" Width="100" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>
        <Button Content="=" Click="Answer" HorizontalAlignment="Left" Height="78" Margin="298,406,0,0" VerticalAlignment="Top" Width="102" FontSize="30" FontFamily="Yu Gothic UI Semibold"/>

    </Grid>
</Window>
